# New Relic Configuration
NEW_RELIC_API_KEY=your_new_relic_api_key_here
NEW_RELIC_ACCOUNT_ID=your_account_id_here
NEW_RELIC_REGION=US  # Options: US, EU

# Server Configuration
NODE_ENV=development  # Options: development, production, test
LOG_LEVEL=info       # Options: debug, info, warn, error

# Cache Configuration (in seconds)
CACHE_TTL_EVENT_TYPES=3600    # 1 hour
CACHE_TTL_ATTRIBUTES=21600    # 6 hours  
CACHE_TTL_METRICS=3600        # 1 hour
CACHE_TTL_ENTITIES=900        # 15 minutes